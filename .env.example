TELEGRAM_TOKEN=your_token_here

# Провайдер LLM: ollama | openai | deepseek
LLM_PROVIDER=ollama

# Ollama (используется всегда для эмбеддингов; для LLM — только при LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (при LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DeepSeek (при LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

DOCS_PATH=/app/docs
CHROMA_PATH=/app/data/chroma
SQLITE_PATH=/app/data/history.db
TOP_K=5
HISTORY_LENGTH=10
CHUNK_SIZE=300
CHUNK_OVERLAP=50
